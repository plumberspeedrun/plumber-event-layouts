{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"googleSpreadsheet": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"credentialsPath": {
					"type": "string"
				},
				"spreadsheetId": {
					"type": "string"
				},
				"runnerSheetName": {
					"type": "string",
					"default": "Runners"
				},
				"commentatorSheetName": {
					"type": "string",
					"default": "Commentators"
				}
			},
			"required": ["credentialsPath", "spreadsheetId"]
		}
	}
}
