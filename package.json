{
	"name": "plumber-event-layouts",
	"version": "1.0.0",
	"description": "",
	"scripts": {
		"start": "npx nodecg start",
		"dev": "run-p dev:*",
		"dev:tsc": "tsc -b src/extension -w --preserveWatchOutput",
		"dev:vite": "vite",
		"dev:nodecg": "npx nodecg start",
		"typecheck": "tsc -b src/extension --noEmit && tsc -p src/browser/tsconfig.json",
		"lint": "eslint . --max-warinings=0",
		"generate-schema-types": "nodecg schema-types -o ./src/nodecg/generated",
		"build": "vite build",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update": "playwright test --update-snapshots",
		"format": "prettier --write src/ schemas/ package.json",
		"format:check": "prettier --check .",
		"clean": "trash node_modules/.cache && trash dashboard && trash extension && trash db && trash graphics",
		"check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@fontsource/m-plus-1p": "^5.2.9",
		"@nodecg/react-hooks": "^1.0.3",
		"googleapis": "^173.0.0",
		"nodecg": "^2.6.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"soundjs": "^1.0.1",
		"trash-cli": "^7.2.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.0",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^10.5.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globby": "^16.2.0",
		"npm-run-all": "^4.1.5",
		"prettier": "3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"rollup": "4.60.1",
		"rollup-plugin-esbuild": "^6.2.1",
		"rollup-plugin-node-externals": "^8.1.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.3",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@vaadin/vaadin-usage-statistics",
			"better-sqlite3",
			"esbuild",
			"msgpackr-extract"
		]
	},
	"nodecg": {
		"dashboardPanels": [
			{
				"name": "example",
				"title": "example",
				"width": 3,
				"file": "example.html",
				"workspace": "Example",
				"headerColor": "#525F78"
			},
			{
				"name": "schedule",
				"title": "スケジュール管理",
				"width": 4,
				"file": "schedule.html",
				"workspace": "Schedule",
				"headerColor": "#525F78"
			},
			{
				"name": "timerControl",
				"title": "タイマー操作",
				"width": 3,
				"file": "timerControl.html",
				"workspace": "Schedule",
				"headerColor": "#525F78"
			},
			{
				"name": "spreadsheetView",
				"title": "スプレッドシート",
				"width": 4,
				"file": "spreadsheetView.html",
				"workspace": "Schedule",
				"headerColor": "#525F78"
			}
		],
		"graphics": [
			{
				"file": "example.html",
				"width": 1920,
				"height": 1080,
				"singleInstance": false
			},
			{
				"file": "SmwRace.html",
				"width": 1920,
				"height": 1080,
				"singleInstance": false
			},
			{
				"file": "ScheduleList.html",
				"width": 1920,
				"height": 1080,
				"singleInstance": false
			}
		],
		"assetCategories": [
			{
				"name": "logo",
				"title": "ロゴ画像",
				"allowedTypes": [
					"svg",
					"png"
				]
			},
			{
				"name": "background",
				"title": "レイアウト画像",
				"allowedTypes": [
					"svg",
					"png"
				]
			}
		]
	}
}
