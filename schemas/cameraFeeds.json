{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"id": {
				"type": "string"
			},
			"label": {
				"type": "string"
			},
			"url": {
				"type": "string"
			},
			"visible": {
				"type": "boolean"
			}
		},
		"required": ["id", "url", "visible"]
	},
	"default": []
}
