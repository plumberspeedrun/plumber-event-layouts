{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "object",
	"additionalProperties": {
		"type": "array",
		"items": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string"
				},
				"pronouns": {
					"type": "string"
				},
				"social": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"twitter": {"type": "string"},
						"twitch": {"type": "string"},
						"youtube": {"type": "string"},
						"niconico": {"type": "string"}
					}
				}
			},
			"required": ["name"]
		}
	},
	"default": {}
}
