{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"relayData": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"game": {
						"type": "string"
					},
					"category": {
						"type": "string"
					},
					"platform": {
						"type": "string"
					},
					"year": {
						"type": "integer"
					},
					"runner": {
						"type": "object",
						"additionalProperties": false,
						"properties": {
							"name": {
								"type": "string"
							},
							"social": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"discord": { "type": "string" },
									"twitch": { "type": "string" },
									"youtube": { "type": "string" },
									"twitter": { "type": "string" },
									"niconico": { "type": "string" }
								}
							}
						},
						"required": ["name"]
					},
					"commentators": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"name": {
									"type": "string"
								},
								"social": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"discord": { "type": "string" },
										"twitch": { "type": "string" },
										"youtube": { "type": "string" },
										"twitter": { "type": "string" },
										"niconico": { "type": "string" }
									}
								}
							},
							"required": ["name"]
						},
						"default": []
					}
				},
				"required": ["game", "category", "platform", "year", "runner"]
			},
			"default": []
		},
		"activeIndex": {
			"type": "integer",
			"default": 0
		}
	},
	"default": { "relayData": [], "activeIndex": 0 }
}
