{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"game": {
				"type": "string"
			},
			"name": {
				"type": "string"
			},
			"pronouns": {
				"type": "string"
			},
			"social": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"twitch": {"type": "string"},
					"youtube": {"type": "string"},
					"twitter": {"type": "string"},
					"niconico": {"type": "string"}
				}
			}
		},
		"required": ["game", "name"]
	},
	"default": []
}
