{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"name": { "type": "string" },
			"role": { "type": "string", "enum": ["runner", "commentator"] },
			"game": { "type": "string" },
			"category": { "type": "string" },
			"teamName": { "type": "string" },
			"social": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"discord": { "type": "string" },
					"twitch": { "type": "string" },
					"youtube": { "type": "string" },
					"twitter": { "type": "string" }
				}
			}
		},
		"required": ["name", "role"]
	},
	"default": []
}
