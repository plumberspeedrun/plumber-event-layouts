{
	"$schema": "http://json-schema.org/draft-07/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"enabled": {
			"type": "boolean",
			"default": false
		},
		"lastSynced": {
			"type": "string"
		},
		"lastError": {
			"type": "string"
		}
	},
	"required": ["enabled"],
	"default": { "enabled": false }
}
